# Auto-generated by Mesh orchestrator — do not edit manually.
worker_processes 1;
daemon off;
pid {{.PidFile}};
error_log {{.ErrorLog}} warn;

events {
    worker_connections 128;
}

http {
    access_log off;

    server {
        listen {{.ListenPort}};

        # Claude API proxy — injects x-api-key header
        location /v1/ {
            proxy_pass https://api.anthropic.com/v1/;
            proxy_set_header x-api-key "{{.ClaudeAPIKey}}";
            proxy_set_header Host api.anthropic.com;
            proxy_ssl_server_name on;
            proxy_buffering off;
            proxy_http_version 1.1;
            proxy_set_header Connection "";
            proxy_read_timeout 600s;
            proxy_send_timeout 600s;
        }

        # Jira API proxy — injects Basic auth header
        location /jira/ {
            proxy_pass {{.JiraEndpoint}}/;
            proxy_set_header Authorization "Basic {{.JiraAuthBase64}}";
            proxy_set_header Content-Type "application/json";
            proxy_set_header Accept "application/json";
            proxy_ssl_server_name on;
            proxy_buffering off;
        }
        {{if .SentryDSN}}
        # Sentry ingest proxy
        location /sentry/ {
            proxy_pass {{.SentryIngestURL}}/;
            proxy_ssl_server_name on;
            proxy_buffering off;
        }
        {{end}}
        # Health check
        location = /health {
            return 200 'ok';
            add_header Content-Type text/plain;
        }
    }
}
